# .env.example
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# -----------------------------------------------
# Kafka — generate once with:
#   docker run --rm apache/kafka:3.7.0 \
#     /opt/kafka/bin/kafka-storage.sh random-uuid
# Pin this value so Kafka data survives recreation.
# -----------------------------------------------
KAFKA_CLUSTER_ID=

# -----------------------------------------------
# Postgres
# -----------------------------------------------
DB_NAME=decisionmesh
DB_USER=decisionmesh
DB_PASSWORD=

# -----------------------------------------------
# Redis
# -----------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------
# OpenBao — set after running `bao operator init`
# This is the root token (or a scoped app token).
# See config/openbao.hcl comments for init steps.
# -----------------------------------------------
VAULT_TOKEN=

# -----------------------------------------------
# API image — built and pushed by your CI pipeline
# e.g. ghcr.io/yourorg/decisionmesh-api:sha-abc123
# -----------------------------------------------
API_IMAGE=
